<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<AssignMessage async="false" continueOnError="false" enabled="true" name="AM-AddCORSHeaders">
    <DisplayName>Add CORS Headers</DisplayName>
    <Properties/>
    <!-- Remove any CORS headers the backend may have set (prevent duplicates) -->
    <Remove>
        <Headers>
            <Header name="Access-Control-Allow-Origin"/>
            <Header name="Access-Control-Allow-Methods"/>
            <Header name="Access-Control-Allow-Headers"/>
            <Header name="Access-Control-Allow-Credentials"/>
            <Header name="Access-Control-Max-Age"/>
            <Header name="Access-Control-Expose-Headers"/>
        </Headers>
    </Remove>
    <!-- Set Apigee-managed CORS headers with the validated origin -->
    <Set>
        <Headers>
            <Header name="Access-Control-Allow-Origin">{cors.allowed_origin}</Header>
            <Header name="Access-Control-Allow-Methods">GET, POST, PUT, DELETE, PATCH, OPTIONS</Header>
            <Header name="Access-Control-Allow-Headers">Origin, X-Requested-With, Content-Type, Accept, Authorization, X-API-Key, X-CSRF-Token, X-Forwarded-Host, X-Origin, X-Referer</Header>
            <Header name="Access-Control-Allow-Credentials">true</Header>
            <Header name="Access-Control-Max-Age">86400</Header>
            <Header name="Access-Control-Expose-Headers">X-Request-Id, X-RateLimit-Limit, X-RateLimit-Remaining</Header>
            <Header name="Vary">Origin</Header>
        </Headers>
    </Set>
    <IgnoreUnresolvedVariables>true</IgnoreUnresolvedVariables>
    <AssignTo createNew="false" transport="http" type="response"/>
</AssignMessage>
