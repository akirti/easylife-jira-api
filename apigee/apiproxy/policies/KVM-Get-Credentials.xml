<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<KeyValueMapOperations async="false" continueOnError="false" enabled="true" name="KVM-Get-Credentials" mapIdentifier="jira-proxykvm">
    <DisplayName>Get Credentials from KVM</DisplayName>
    <Properties/>
    <ExpiryTimeInSecs>300</ExpiryTimeInSecs>
    <Get assignTo="private.p.jira.hostname">
        <Key>
            <Parameter>hostname</Parameter>
        </Key>
    </Get>
    <Get assignTo="private.jwt.secret">
        <Key>
            <Parameter>secretKey</Parameter>
        </Key>
    </Get>
    <Scope>environment</Scope>
</KeyValueMapOperations>
