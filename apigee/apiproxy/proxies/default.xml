<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<ProxyEndpoint name="default">
    <Description>Default Proxy Endpoint for Jira Dashboard API</Description>

    <PreFlow name="PreFlow">
        <Request>
            <!-- Validate CORS origin against allowed list (runs for ALL requests including OPTIONS) -->
            <Step>
                <Name>JS-ValidateCORSOrigin</Name>
            </Step>
            <!-- CORS Preflight: return 200 with headers for valid origins -->
            <Step>
                <Name>RF-CORSPreflight</Name>
                <Condition>request.verb == "OPTIONS" and cors.is_valid_origin == "true"</Condition>
            </Step>
            <!-- CORS Preflight: reject invalid origins with 403 -->
            <Step>
                <Name>RF-CORSInvalidOrigin</Name>
                <Condition>request.verb == "OPTIONS" and cors.is_valid_origin != "true"</Condition>
            </Step>
            <!-- Retrieve credentials (hostname, JWT secret) from encrypted KVM - MUST run before JWT verification -->
            <Step>
                <Name>KVM-Get-Credentials</Name>
                <Condition>request.verb != "OPTIONS" and !(proxy.pathsuffix JavaRegex "/(health|health/.*)")</Condition>
            </Step>
            <!-- Spike Arrest to prevent abuse (rate limit by client IP) -->
            <Step>
                <Name>SA-RateLimit</Name>
                <Condition>!(proxy.pathsuffix JavaRegex "/(health|health/.*)")</Condition>
            </Step>
            <!-- Extract access_token from httpOnly cookie into Authorization header (for page-refresh flows) -->
            <Step>
                <Name>JS-ExtractCookieToken</Name>
                <Condition>(proxy.pathsuffix != "" and proxy.pathsuffix != "/") and !(proxy.pathsuffix JavaRegex "/(health|health/.*)") and request.verb != "OPTIONS"</Condition>
            </Step>
            <!-- Validate JWT Token for protected endpoints -->
            <Step>
                <Name>JWT-VerifyAccessToken</Name>
                <Condition>(proxy.pathsuffix != "" and proxy.pathsuffix != "/") and !(proxy.pathsuffix JavaRegex "/(health|health/.*)") and request.verb != "OPTIONS"</Condition>
            </Step>
            <!-- Quota enforcement (by JWT user or client IP) -->
            <Step>
                <Name>Q-EnforceQuota</Name>
                <Condition>(proxy.pathsuffix != "" and proxy.pathsuffix != "/") and !(proxy.pathsuffix JavaRegex "/(health|health/.*)") and request.verb != "OPTIONS"</Condition>
            </Step>
        </Request>
        <Response>
            <!-- Add CORS headers to responses (only for validated origins) -->
            <Step>
                <Name>AM-AddCORSHeaders</Name>
                <Condition>cors.is_valid_origin == "true"</Condition>
            </Step>
        </Response>
    </PreFlow>

    <Flows>
        <!-- ==================== Health Check Endpoints (Public) ==================== -->
        <Flow name="Health-Live">
            <Description>Liveness probe</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/health/live") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Health-Ready">
            <Description>Readiness probe</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/health/ready") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Health">
            <Description>Health check endpoint</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/health")</Condition>
        </Flow>

        <Flow name="Health-Sub">
            <Description>Health sub-endpoints</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/health/*")</Condition>
        </Flow>

        <!-- ==================== Dashboard Endpoints (Authenticated) ==================== -->
        <Flow name="Dashboard-Stats">
            <Description>Get dashboard statistics</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/stats") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Dashboard-Issues">
            <Description>Get dashboard issues</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/issues") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Dashboard-Canvas">
            <Description>Get dashboard canvas</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/canvas") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Dashboard-Timeline">
            <Description>Get dashboard timeline</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/timeline") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Dashboard-Mentions">
            <Description>Get dashboard mentions</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/mentions") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Dashboard-Boards">
            <Description>Get dashboard boards</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/boards") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Dashboard-Blockers">
            <Description>Get dashboard blockers</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/blockers") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Dashboard-Catchall">
            <Description>Dashboard catch-all for other GET endpoints</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/dashboard/*") and (request.verb = "GET")</Condition>
        </Flow>

        <!-- ==================== Issues Endpoints ==================== -->
        <Flow name="Issues-Create">
            <Description>Create a new issue (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/issues/create") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Issues-Link">
            <Description>Link issues (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/issues/*/link") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Issues-Transition">
            <Description>Transition an issue (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/issues/*/transition") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Issues-Detail">
            <Description>Get issue detail (authenticated)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/issues/*") and (request.verb = "GET")</Condition>
        </Flow>

        <!-- ==================== Portfolio Endpoints ==================== -->
        <Flow name="Portfolio-ExportDocx">
            <Description>Export portfolio as DOCX</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/exports/portfolio") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Portfolio-Recompute">
            <Description>Recompute portfolio rollups (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/recompute") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Portfolio-SnapshotsRun">
            <Description>Take a portfolio snapshot (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/snapshots/run") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Portfolio-Capabilities">
            <Description>Get portfolio capabilities</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/capabilities") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Portfolio-Tree">
            <Description>Get portfolio tree</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/tree") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Portfolio-Children">
            <Description>Get portfolio children</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/children") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Portfolio-Snapshots">
            <Description>Get portfolio snapshots</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/snapshots") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Portfolio-Cycle">
            <Description>Get portfolio cycle</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/cycle") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Portfolio-Related">
            <Description>Get portfolio related items</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/related") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Portfolio-Catchall">
            <Description>Portfolio catch-all for other endpoints</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/portfolio/*")</Condition>
        </Flow>

        <!-- ==================== Sync Endpoints (Admin Only) ==================== -->
        <Flow name="Sync-Trigger">
            <Description>Trigger Jira sync (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/sync/trigger") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Sync-Progress">
            <Description>Get sync progress (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/sync/progress") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Sync-ConfigGet">
            <Description>Get sync config (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/sync/config") and (request.verb = "GET")</Condition>
        </Flow>

        <Flow name="Sync-ConfigUpdate">
            <Description>Update sync config (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/sync/config") and (request.verb = "PUT")</Condition>
        </Flow>

        <Flow name="Sync-Archive">
            <Description>Archive issues (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/sync/archive") and (request.verb = "POST")</Condition>
        </Flow>

        <Flow name="Sync-ArchivesList">
            <Description>List archives (admin only)</Description>
            <Request/>
            <Response/>
            <Condition>(proxy.pathsuffix MatchesPath "/sync/archives") and (request.verb = "GET")</Condition>
        </Flow>

        <!-- Default catch-all: pass through to backend (let backend return 404 for unknown routes) -->
        <Flow name="DefaultPassthrough">
            <Description>Pass through to backend for any routes not explicitly handled above</Description>
            <Request/>
            <Response/>
        </Flow>
    </Flows>

    <PostFlow name="PostFlow">
        <Request/>
        <Response>
            <!-- Add security headers -->
            <Step>
                <Name>AM-AddSecurityHeaders</Name>
            </Step>
        </Response>
    </PostFlow>

    <FaultRules>
        <!-- CORS preflight: RaiseFault already set the response — skip all error overrides -->
        <FaultRule name="CORSPreflight">
            <Condition>request.verb == "OPTIONS"</Condition>
            <!-- No steps — let the RaiseFault response (200 or 403) pass through unchanged -->
        </FaultRule>
        <FaultRule name="InvalidJWT">
            <Step>
                <Name>AM-InvalidJWTResponse</Name>
            </Step>
            <Condition>(fault.name Matches "*JWT*") or (fault.name Matches "*jwt*")</Condition>
        </FaultRule>
        <FaultRule name="QuotaViolation">
            <Step>
                <Name>AM-QuotaExceededResponse</Name>
            </Step>
            <Condition>(fault.name = "QuotaViolation")</Condition>
        </FaultRule>
        <FaultRule name="SpikeArrestViolation">
            <Step>
                <Name>AM-RateLimitExceededResponse</Name>
            </Step>
            <Condition>(fault.name = "SpikeArrestViolation")</Condition>
        </FaultRule>
    </FaultRules>

    <DefaultFaultRule name="DefaultFaultRule">
        <Step>
            <Name>AM-DefaultErrorResponse</Name>
            <Condition>request.verb != "OPTIONS" and !(fault.name Matches "*JWT*") and !(fault.name Matches "*jwt*") and !(fault.name = "QuotaViolation") and !(fault.name = "SpikeArrestViolation")</Condition>
        </Step>
        <!-- Add CORS headers to ALL error responses so browsers can read them -->
        <Step>
            <Name>AM-AddCORSHeaders</Name>
            <Condition>request.verb != "OPTIONS" and cors.is_valid_origin == "true"</Condition>
        </Step>
        <AlwaysEnforce>true</AlwaysEnforce>
    </DefaultFaultRule>

    <HTTPProxyConnection>
        <BasePath>/jira/v1</BasePath>
        <Properties/>
        <VirtualHost>secure</VirtualHost>
        <VirtualHost>default</VirtualHost>
    </HTTPProxyConnection>

    <RouteRule name="noroute">
        <Condition>request.verb == "OPTIONS"</Condition>
    </RouteRule>
    <!-- Infrastructure routes go to target WITHOUT /api/v1 prefix -->
    <RouteRule name="infrastructure">
        <Condition>(proxy.pathsuffix MatchesPath "/health") or (proxy.pathsuffix MatchesPath "/health/*")</Condition>
        <TargetEndpoint>infrastructure</TargetEndpoint>
    </RouteRule>
    <!-- Business API routes go to target WITH /api/v1 prefix -->
    <RouteRule name="default">
        <TargetEndpoint>default</TargetEndpoint>
    </RouteRule>
</ProxyEndpoint>
