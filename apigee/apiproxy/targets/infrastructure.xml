<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<TargetEndpoint name="infrastructure">
    <Description>Target Endpoint for infrastructure routes (health) — no /api/v1 prefix</Description>

    <PreFlow name="PreFlow">
        <Request>
            <!-- Set target headers -->
            <Step>
                <Name>AM-SetTargetHeaders</Name>
            </Step>
        </Request>
        <Response/>
    </PreFlow>

    <Flows/>

    <PostFlow name="PostFlow">
        <Request/>
        <Response>
            <!-- Log response for analytics -->
            <Step>
                <Name>JS-LogResponse</Name>
            </Step>
        </Response>
    </PostFlow>

    <FaultRules>
        <FaultRule name="TargetUnavailable">
            <Step>
                <Name>AM-TargetUnavailableResponse</Name>
            </Step>
            <Condition>(fault.name = "ConnectionRefused") or (fault.name = "ConnectionTimeout")</Condition>
        </FaultRule>
    </FaultRules>

    <DefaultFaultRule name="DefaultTargetFaultRule">
        <Step>
            <Name>AM-DefaultTargetErrorResponse</Name>
        </Step>
        <AlwaysEnforce>true</AlwaysEnforce>
    </DefaultFaultRule>

    <HTTPTargetConnection>
        <Properties>
            <Property name="keepalive.timeout.millis">60000</Property>
            <Property name="connect.timeout.millis">30000</Property>
            <Property name="io.timeout.millis">60000</Property>
        </Properties>
        <!-- Same load balancer as default, but NO /api/v1 path prefix -->
        <LoadBalancer>
            <Algorithm>RoundRobin</Algorithm>
            <Server name="jira-backend-1"/>
            <Server name="jira-backend-2"/>
            <MaxFailures>3</MaxFailures>
            <RetryEnabled>true</RetryEnabled>
        </LoadBalancer>
        <!-- No <Path> element: requests forwarded with pathsuffix only -->
    </HTTPTargetConnection>
</TargetEndpoint>
